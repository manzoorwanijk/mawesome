{
	"name": "@mawesome/site",
	"version": "0.0.0",
	"private": true,
	"description": "mawesome — docs + interactive playgrounds for the @mawesome/* tools",
	"type": "module",
	"scripts": {
		"sync:docs": "node scripts/sync-docs.ts",
		"dev": "pnpm run sync:docs && astro dev",
		"build": "pnpm run sync:docs && astro build",
		"preview": "astro preview",
		"typecheck": "pnpm run sync:docs && astro sync && astro-check",
		"parity": "node scripts/parity.ts"
	},
	"dependencies": {
		"@astrojs/starlight": "^0.39.3",
		"@mawesome/dependency-audit": "workspace:*",
		"astro": "^6.4.3",
		"nanotar": "^0.3.0",
		"pathe": "^2.0.3"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"typescript": "^6.0.3"
	}
}
