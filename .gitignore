# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Test / coverage
coverage/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
.idea/
*.swp

# Env
.env
.env.*
!.env.example

# Only the project-scoped Claude commands/skills are versioned; everything else under `.claude/`
# is machine-local (settings.local.json, scheduled_tasks.lock, …) and stays out of git.
# `!.claude/` first overrides a global `.claude/` ignore so the negations below can take effect.
!.claude/
.claude/*
!.claude/commands/
!.claude/skills/

# VS Code: recommended settings are opt-in via `pnpm vscode:setup` (settings.dist.jsonc);
# the generated local copy is the developer's own.
.vscode/settings.json


# Local scratch (e.g. the monorepo setup plan) — not tracked.
temp/
