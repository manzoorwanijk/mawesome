{
	// Formatting and linting are powered by the oxc toolchain (oxfmt + oxlint).
	// Install the recommended "oxc.oxc-vscode" extension (see extensions.json).
	"editor.formatOnSave": true,
	"editor.defaultFormatter": "oxc.oxc-vscode",
	"[javascript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
	"[typescript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
	"[json]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
	"[jsonc]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
	"[yaml]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
	"[markdown]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
	// Type-checking on the CLI uses tsgo (@typescript/native-preview). To mirror it in
	// the editor, install the "TypeScript (Native Preview)" extension and enable:
	"typescript.experimental.useTsgo": true
}
