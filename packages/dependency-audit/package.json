{
	"name": "@mawesome/dependency-audit",
	"version": "0.3.1",
	"description": "Verify every reachable bare import in a package's released artifact is declared and resolvable",
	"keywords": [
		"audit",
		"d.ts",
		"dependencies",
		"exports",
		"npm",
		"publint",
		"types"
	],
	"homepage": "https://github.com/manzoorwanijk/mawesome/tree/main/packages/dependency-audit#readme",
	"bugs": "https://github.com/manzoorwanijk/mawesome/issues",
	"license": "MIT",
	"author": "Manzoor Ahmad Wani",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/manzoorwanijk/mawesome.git",
		"directory": "packages/dependency-audit"
	},
	"bin": {
		"dependency-audit": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"typesVersions": {
		"*": {
			"browser": [
				"./dist/browser.d.cts"
			]
		}
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./browser": {
			"import": {
				"types": "./dist/browser.d.ts",
				"default": "./dist/browser.js"
			},
			"require": {
				"types": "./dist/browser.d.cts",
				"default": "./dist/browser.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsgo",
		"test": "vitest run",
		"check:exports": "attw --pack . --profile node16 && publint --strict"
	},
	"dependencies": {
		"npm-packlist": "^10.0.4",
		"pacote": "^21.5.0",
		"resolve.exports": "^2.0.3",
		"tar": "^7.5.16",
		"typescript": "^6.0.3"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.3",
		"@mawesome/tsconfig": "workspace:*",
		"@types/node": "^24.12.4",
		"@types/pacote": "^11.1.8",
		"@typescript/native-preview": "7.0.0-dev.20260527.2",
		"publint": "^0.3.21",
		"tsdown": "^0.22.1",
		"vitest": "^4.1.7"
	},
	"engines": {
		"node": ">=24.12.0"
	}
}
